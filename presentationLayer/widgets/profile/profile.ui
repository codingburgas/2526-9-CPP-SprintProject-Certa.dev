  <property name="windowTitle">
   <string>Profile</string>
  </property>
  <property name="styleSheet">
   <string notr="true">#Profile {
    background-color: #0F0F11;
}
QScrollArea {
    border: none;
    background-color: transparent;
}
QScrollArea > QWidget#qt_scrollarea_viewport {
    background-color: transparent;
}
#profileScrollContent,
#headerCard,
#statsRow,
#genresSection,
#favoritesSection,
#favoritesPreviewStack,
#favoritesPreviewGridPage,
#favoritesPreviewEmptyPage,
#genresStack,
#genresChipsPage,
#genresEmptyPage,
#genresChipsRow {
    background-color: transparent;
}
#headerCard {
    background-color: #181818;
    border: 1px solid #181818;
    border-radius: 12px;
}
#avatarLabel {
    background-color: #AE1A19;
    color: #FFFFFF;
    border-radius: 40px;
    font-size: 32px;
    font-weight: 700;
    min-width: 80px;
    min-height: 80px;
    max-width: 80px;
    max-height: 80px;
}
#usernameLabel {
    color: #FFFFFF;
    font-size: 22px;
    font-weight: 700;
}
#memberLabel {
    color: #6C6C6E;
    font-size: 12px;
}
#editProfileButton {
    background-color: #AE1A19;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
}
#editProfileButton:hover {
    background-color: #951615;
}
#logoutButton {
    background-color: transparent;
    color: #EF4444;
    border: 1px solid #EF4444;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
}
#logoutButton:hover {
    background-color: rgba(239, 68, 68, 0.08);
}
#favoritesStatTile,
#genresStatTile,
#recommendationsStatTile {
    background-color: #181818;
    border: 1px solid #181818;
    border-radius: 10px;
}
#favoritesStatValue,
#genresStatValue,
#recommendationsStatValue {
    color: #FFFFFF;
    font-size: 24px;
    font-weight: 700;
}
#favoritesStatLabel,
#genresStatLabel,
#recommendationsStatLabel {
    color: #6C6C6E;
    font-size: 12px;
}
#genresTitleLabel,
#favoritesTitleLabel {
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 600;
}
#viewAllFavoritesButton {
    background-color: transparent;
    color: #AE1A19;
    border: none;
    font-size: 13px;
    font-weight: 600;
}
#viewAllFavoritesButton:hover {
    color: #951615;
}
#emptyGenresLabel,
#emptyFavoritesLabel {
    color: #6C6C6E;
    font-size: 13px;
}
#openSettingsLink {
    background-color: transparent;
    color: #AE1A19;
    border: none;
    font-size: 13px;
    font-weight: 600;
    text-align: left;
    padding: 0;
}
#openSettingsLink:hover {
    color: #951615;
}
QFrame#movieCard {
    background-color: #181818;
    border-radius: 8px;
    border: 1px solid #181818;
}
QFrame#movieCard:hover {
    background-color: #232325;
    border: 1px solid #2A2A2C;
}
QLabel#movieCardTitle {
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 600;
}
QLabel#movieCardGenres {
    color: #6C6C6E;
    font-size: 11px;
}
QLabel#movieCardRating {
    color: #FFFFFF;
    font-size: 12px;
}
QLabel#movieCardReviews {
    color: #6C6C6E;
    font-size: 12px;
}</string>
