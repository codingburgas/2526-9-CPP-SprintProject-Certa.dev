    border: 1px solid #181818;
    border-radius: 14px;
    color: #FFFFFF;
    font-size: 13px;
    padding-left: 14px;
    padding-right: 14px;
    min-height: 28px;
    min-width: 140px;
}
QComboBox#sortComboBox:hover, QComboBox#genreComboBox:hover,
QComboBox#sortComboBox:focus, QComboBox#genreComboBox:focus {
    border: 1px solid #AE1A19;
}
QComboBox#sortComboBox::drop-down, QComboBox#genreComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox QAbstractItemView {
    background-color: #181818;
    color: #FFFFFF;
    selection-background-color: #AE1A19;
