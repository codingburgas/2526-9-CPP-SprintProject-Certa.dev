  <property name="styleSheet">
   <string notr="true">#Actor {
    background-color: #0F0F11;
}
QScrollArea {
    border: none;
    background-color: transparent;
}
QScrollArea > QWidget#qt_scrollarea_viewport {
    background-color: transparent;
}
#actorScrollContent {
    background-color: transparent;
}
QPushButton#actorBackButton {
    color: #FFFFFF;
    background-color: #181818;
    border: 1px solid #181818;
    border-radius: 8px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
}
QPushButton#actorBackButton:hover {
    background-color: #232325;
    border-color: #2A2A2C;
}
QLabel#actorNameLabel {
    color: #FFFFFF;
    font-size: 24px;
    font-weight: 700;
}
QLabel#actorMetaLabel {
    color: #6C6C6E;
    font-size: 13px;
}
QLabel#actorDescriptionLabel {
    color: #E6E6E6;
    font-size: 14px;
    line-height: 1.4;
}
QLabel#actorPosterLabel {
    background-color: #181818;
    border-radius: 8px;
}
QLabel#filmographyTitleLabel {
    color: #FFFFFF;
    font-size: 18px;
    font-weight: 700;
}
QLabel#filmographyEmptyLabel {
    color: #6C6C6E;
    font-size: 13px;
}
QFrame#movieCard {
    background-color: #181818;
    border-radius: 8px;
    border: 1px solid #181818;
}
QFrame#movieCard:hover {
    background-color: #232325;
    border: 1px solid #2A2A2C;
}
QLabel#movieCardTitle {
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 600;
}
QLabel#movieCardGenres {
    color: #6C6C6E;
    font-size: 11px;
}
QLabel#movieCardRating {
    color: #FFFFFF;
    font-size: 12px;
}
QLabel#movieCardReviews {
    color: #6C6C6E;
    font-size: 12px;
}</string>
