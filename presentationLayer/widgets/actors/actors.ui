    padding-left: 6px;
}
QComboBox QAbstractItemView::item:hover {
    background-color: #951615;
    color: #FFFFFF;
}
QComboBox QAbstractItemView::item:selected {
    background-color: #AE1A19;
    color: #FFFFFF;
